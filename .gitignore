# ====================
# AIAGRO — .gitignore
# ====================

# Secretos y variables de entorno — NUNCA en repositorio
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.staging
.env.prod
*.env

# El .env.example SÍ se incluye (no tiene valores reales)
!.env.example

# Dependencias
node_modules/
.pnp
.pnp.js

# Build outputs
.next/
out/
build/
dist/

# Caché y temporales
.cache/
.turbo/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# IDEs y editores
.vscode/
.idea/
*.swp
*.swo

# Python
__pycache__/
*.py[cod]
*.pyo
venv/
.venv/

# Supabase local
supabase/.branches/
supabase/.temp/

# Certificados y claves
*.pem
*.key
*.cert
*.p12
*.pfx

# Datos reales
data/real/
data/prod/
uploads/real/
